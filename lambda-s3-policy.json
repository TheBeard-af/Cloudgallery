{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowReadOriginalImages",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::cloudgallery-images-2026/*"
    },
    {
      "Sid": "AllowWriteThumbnails",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::cloudgallery-thumbnails-2026/*"
    }
  ]
}
