{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowImageBucketAccess",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::cloudgallery-images-2026/*"
    },
    {
      "Sid": "AllowListBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::cloudgallery-images-2026"
    }
  ]
}
